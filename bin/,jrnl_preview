#!/usr/bin/env bash

set -Eeuo pipefail

function show() {
  tags=$(jrnl -on "${1}" --tags)

  if [[ ${tags::1} == "[" ]] ; then
    printf "" # [No tags found in journal.]
  else
    printf "# $(echo "${tags}" | awk '{ print $1 }' ORS=' ')"
  fi

  printf "\n$(jrnl -on "${1}" --format text)" 
}

for date in "$@"
do  
  show "${date}" | \
    bat --force-colorization \
      --highlight-line 2 \
      --language md \
      --plain
done
