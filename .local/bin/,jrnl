#!/usr/bin/env bash

set -Eeuo pipefail

SCRIPT_DIR=$(cd "$(dirname "${BASH_SOURCE[0]}")" &>/dev/null && pwd -P)
DAYONE_PATH="$(jrnl --list | tail --lines=2 | head --lines=1 | cut -f5- -d' ')"
readonly DAYONE_PATH="${DAYONE_PATH/#\~/$HOME}"
export DAYONE_PATH
INITIAL_QUERY="${*:-}"


function reload() {
    if [ -z "${1}" ]; then
        jrnl --short
        return
    fi
    matches1=$(jrnl --short $(echo "$@" | awk -v OFS=' -and -contains ' '{if(NR=1) $1="-contains "$1; print}'))
    matches2=$(jrnl --short $(echo "$@" | awk -v OFS=' -and ' '{gsub(/^| /,"&@")} $1=$1'))
    if [ -z "${matches2}" ]; then
        echo "${matches1}"
    else
        sort --unique <(echo "${matches1}") <(echo "${matches2}") | grep .
    fi
}
export -f reload


function prepare() {
    dayone_id=$(jrnl -on "${1}" \
        --config-override editor "tail --lines=1" \
        --edit | \
        cut -c "3-")

    dayone_image="${DAYONE_PATH}/photos/${dayone_id}.jpg"

    [ -f "${dayone_image}" ] && printf '![](%s){ width=500px }\n' "${dayone_image}"

    printf '\n'
    jrnl -on "${1}" --format markdown
}
export -f prepare


function show() {
    if [ -z "${1+x}" ]; then
        return
    fi

    prepare "${1}" | \
        pandoc --from=markdown | \
        ,w3m -T text/html
}
export -f show


FZF_DEFAULT_COMMAND="reload $(printf %q "${INITIAL_QUERY}")" \
fzf --ansi \
    --bind 'change:reload:sleep 0.1; reload {q}' \
    --bind 'enter:execute(show {+1..2} > /dev/tty)' \
    --disabled \
    --exact \
    --multi \
    --no-sort \
    --preview="${SCRIPT_DIR}/,jrnl_preview {+1..2}" \
    --preview-window=wrap \
    --query "${INITIAL_QUERY}" \
    --with-nth=1,3.. \
    --tac
