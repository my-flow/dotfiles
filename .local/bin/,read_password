#!/usr/bin/env bash

set -Eeuo pipefail

SCRIPT_DIR=$(cd "$(dirname "${BASH_SOURCE[0]}")" &>/dev/null && pwd -P)

export KPAT=${2:-password}

# shellcheck source=./.kp.function
source "${SCRIPT_DIR}"/.kp.function

keepassxc-cli show \
  --attributes "${KPAT}" \
  --show-protected \
  --quiet \
  "${KPDB}" \
  "${1}" < <(printf '%s' "${KPPW}") 2>/dev/null
